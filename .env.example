# Arkon — AI Operations Control Plane
# Copy this file to .env.local and fill in the values.
# Docs: https://github.com/arkon-platform/arkon#configuration

# ═══════════════════════════════════════════════════════════════════════════
# REQUIRED
# ═══════════════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────────────
# PostgreSQL/TimescaleDB connection string
# For Docker Compose: postgresql://arkon:arkon@db:5432/arkon
DATABASE_URL=postgresql://arkon:your-db-password@localhost:5432/arkon

# ── Authentication ────────────────────────────────────────────────────────
# Admin passphrase for owner-level login and API access (min 12 chars)
MC_ADMIN_TOKEN=change-me-to-a-secure-passphrase

# Agent ingest tokens (format: tenant_name:token,tenant_name:token)
# Agents use these to authenticate when sending events to /api/ingest
MC_AGENT_TOKENS=default:change-me-to-a-secure-token

# ── Application ───────────────────────────────────────────────────────────
# Base URL where Arkon is accessible (used for internal API calls, links)
ARKON_BASE_URL=http://localhost:3000

# NextAuth secret for session encryption (generate: openssl rand -base64 32)
NEXTAUTH_SECRET=change-me-generate-with-openssl
NEXTAUTH_URL=http://localhost:3000

# ═══════════════════════════════════════════════════════════════════════════
# OPTIONAL — Agent Framework Integration
# ═══════════════════════════════════════════════════════════════════════════

# ── OpenClaw / NemoClaw Gateway ───────────────────────────────────────────
# URL of your OpenClaw or NemoClaw gateway (for agent control: kill, pause, wake)
# NEXT_PUBLIC_GATEWAY_URL=http://your-gateway-host:18789

# Auth token for gateway hook callbacks
# GATEWAY_HOOK_TOKEN=

# Auth token for gateway API access
# GATEWAY_AUTH_TOKEN=

# URL where the gateway sends webhook events back to Arkon
# GATEWAY_HOOKS_URL=https://your-arkon-url/api/ingest

# ═══════════════════════════════════════════════════════════════════════════
# OPTIONAL — Notifications
# ═══════════════════════════════════════════════════════════════════════════

# ── Telegram Alerts ───────────────────────────────────────────────────────
# Bot token from @BotFather and target chat ID for alert notifications
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Separate Telegram config for threat/anomaly alerts (falls back to above)
# ALERT_TELEGRAM_BOT_TOKEN=
# ALERT_TELEGRAM_CHAT_ID=

# ── Web Push (PWA) ──────────────────────────────────────────────────────
# VAPID keys for browser push notifications (generate: npx web-push generate-vapid-keys)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=  # Same as VAPID_PUBLIC_KEY — exposed to client
# VAPID_EMAIL=admin@arkon.dev

# ═══════════════════════════════════════════════════════════════════════════
# OPTIONAL — Infrastructure Monitoring
# ═══════════════════════════════════════════════════════════════════════════

# Cron secret for scheduled infrastructure collection jobs
# CRON_SECRET=

# SSH key path for remote node collection (advanced — prefer push-based reporting)
# MC_CRON_KEY_PATH=~/.ssh/mc_cron_key

# ═══════════════════════════════════════════════════════════════════════════
# OPTIONAL — Advanced
# ═══════════════════════════════════════════════════════════════════════════

# Provisioning token for automated tenant/agent creation via API
# MC_PROVISIONING_TOKEN=

# Node environment (production, development, test)
NODE_ENV=production

# Port (default: 3000)
PORT=3000
